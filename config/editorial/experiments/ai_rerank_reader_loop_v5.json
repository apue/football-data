{
  "id": "ai_rerank_reader_loop_v5",
  "workflow_variant": "ai_rerank_selection_v1",
  "scoring_config": "config/scoring/v0.4.json",
  "candidate_pool": "guarded_packet_v2",
  "selector_profile": "slate_balanced_editor_v3",
  "review_profile": "reader_intuition_loop_v2",
  "revision_policy": {
    "mode": "reader_critic_revise_review_loop",
    "max_revision_rounds": 2,
    "blocking_review_requires_revision": true,
    "revision_targets": [
      "selection_decision",
      "copy",
      "review"
    ]
  },
  "reader_intuition_loop": {
    "mode": "slate_critic_then_revision",
    "critic_outputs": [
      "match_coverage_pressure",
      "reader_questions",
      "alternative_slate_comparison",
      "weakest_selected_card",
      "strongest_omitted_card",
      "revision_decision"
    ],
    "human_review_trigger": [
      "top_three_direct_impact_omitted",
      "fact_mismatch_between_timeline_and_candidate_pool"
    ]
  },
  "copy_profiles": {
    "zh": "zh_matchnote_light_emotion_v1",
    "en": "en_plain_v1"
  },
  "selection": {
    "mode": "ai_rerank_only",
    "strategy": "overall_slate_v1",
    "public_card_count": {
      "min": 3,
      "max": 6
    },
    "award_limits": {
      "player_of_the_day": 6,
      "impact_pick": 2
    },
    "overall_slate_award_preference": [
      "player_of_the_day",
      "impact_pick"
    ],
    "slate_constraints": {
      "max_per_match": 3,
      "max_per_team": 3
    },
    "slate_balance": {
      "default_max_public_cards_per_match": 2,
      "award_types_are_angles_not_quotas": true,
      "angle_awards_can_be_omitted": [
        "impact_pick"
      ],
      "third_card_requires": [
        "top_five_rank_cluster",
        "dominant_team_result",
        "independent_direct_contribution",
        "strong_supporting_metric_profile",
        "hat_trick",
        "late_match_winning_goal"
      ]
    },
    "must_explain_skipped_higher_ranked_candidates": true
  },
  "shuffle_strategy": "name_sorted",
  "status": "active"
}
